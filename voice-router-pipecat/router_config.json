{
  "framework": "pipecat",
  "stt_notes": "Moonshine/Moon-whatever small streaming STT is a good candidate, but STT model is not locked yet.",
  "tts_default": true,
  "routes": [
    {
      "name": "scroll_down",
      "description": "Scroll the focused window down. urxvt/terminal uses Shift+PageDown scrollback; other apps use PageDown.",
      "match": [
        "scroll down",
        "go down",
        "page down",
        "move down"
      ],
      "route": "computer_control",
      "function": "scroll",
      "args": {
        "direction": "down"
      },
      "tts": false
    },
    {
      "name": "scroll_up",
      "description": "Scroll the focused window up. urxvt/terminal uses Shift+PageUp scrollback; other apps use PageUp.",
      "match": [
        "scroll up",
        "go up",
        "page up",
        "move up"
      ],
      "route": "computer_control",
      "function": "scroll",
      "args": {
        "direction": "up"
      },
      "tts": false
    },
    {
      "name": "focus_left",
      "description": "Move i3 window focus left using i3 directional focus.",
      "match": [
        "focus left",
        "move focus left",
        "move window focus left",
        "window focus left",
        "go left"
      ],
      "route": "computer_control",
      "function": "focus_direction",
      "args": {
        "direction": "left"
      },
      "tts": false
    },
    {
      "name": "focus_right",
      "description": "Move i3 window focus right using i3 directional focus.",
      "match": [
        "focus right",
        "move focus right",
        "move window focus right",
        "window focus right",
        "go right"
      ],
      "route": "computer_control",
      "function": "focus_direction",
      "args": {
        "direction": "right"
      },
      "tts": false
    },
    {
      "name": "focus_up",
      "description": "Move i3 window focus up using i3 directional focus.",
      "match": [
        "focus up",
        "move focus up",
        "move window focus up",
        "window focus up",
        "go up"
      ],
      "route": "computer_control",
      "function": "focus_direction",
      "args": {
        "direction": "up"
      },
      "tts": false
    },
    {
      "name": "focus_down",
      "description": "Move i3 window focus down using i3 directional focus.",
      "match": [
        "focus down",
        "move focus down",
        "move window focus down",
        "window focus down",
        "go down"
      ],
      "route": "computer_control",
      "function": "focus_direction",
      "args": {
        "direction": "down"
      },
      "tts": false
    },
    {
      "name": "make_full_screen",
      "description": "Toggle fullscreen for the currently focused i3 window using default i3 behavior.",
      "match": [
        "make full screen",
        "make fullscreen",
        "fullscreen",
        "full screen",
        "toggle full screen",
        "toggle fullscreen"
      ],
      "route": "computer_control",
      "function": "make_full_screen",
      "args": {},
      "tts": false
    },
    {
      "name": "exit_full_screen",
      "description": "Exit fullscreen for the currently focused i3 window using default i3 behavior.",
      "match": [
        "exit fullscreen",
        "exit full screen",
        "leave fullscreen",
        "leave full screen",
        "disable fullscreen",
        "disable full screen"
      ],
      "route": "computer_control",
      "function": "exit_full_screen",
      "args": {},
      "tts": false
    },
    {
      "name": "list_routed_commands",
      "description": "List all directly routed voice commands and what they do.",
      "match": [
        "list all routed commands",
        "list routed commands",
        "what commands can i say",
        "show routed commands",
        "show voice commands"
      ],
      "route": "router_help",
      "function": "list_routed_commands",
      "args": {},
      "tts": true
    },
    {
      "name": "close_youtube",
      "description": "Close any open mpv windows (YouTube playback). No-op if mpv is not open. Silent computer action; no TTS.",
      "match": [
        "close youtube",
        "stop youtube",
        "close mpv",
        "stop mpv",
        "close the video",
        "stop the video",
        "stop playing youtube"
      ],
      "route": "computer_control",
      "function": "close_youtube",
      "args": {},
      "tts": false
    },
    {
      "name": "open_pig_io_overlay",
      "description": "Switch to the pig-io overlay workspace (workspace 1).",
      "match": [
        "open pig",
        "open peg",
        "open pick",
        "open pie",
        "opened pig",
        "show pig",
        "show peg",
        "show pick",
        "open overlay",
        "show overlay",
        "open pig overlay",
        "show pig overlay",
        "open voice overlay",
        "show voice overlay",
        "go to workspace 1",
        "go workspace 1",
        "workspace 1",
        "switch to workspace 1",
        "switch workspace 1"
      ],
      "route": "computer_control",
      "function": "open_pig_io_overlay",
      "args": {},
      "tts": false
    },
    {
      "name": "focus_pig_io_overlay",
      "description": "Switch to and focus the pig-io overlay workspace (workspace 1).",
      "match": [
        "focus pig",
        "focus peg",
        "focus overlay",
        "focus pig overlay",
        "focus voice overlay"
      ],
      "route": "computer_control",
      "function": "focus_pig_io_overlay",
      "args": {},
      "tts": false
    },
    {
      "name": "close_pig_io_overlay",
      "description": "Leave the pig-io overlay workspace and return to workspace 2.",
      "match": [
        "close pig",
        "close peg",
        "close pay",
        "close pie",
        "closed pig",
        "clothes pig",
        "close pick",
        "close big",
        "close peak",
        "close pigg",
        "hide pig",
        "hide peg",
        "close overlay",
        "close over leg",
        "close the overlay",
        "hide overlay",
        "close pig overlay",
        "hide pig overlay",
        "close voice overlay",
        "hide voice overlay",
        "go to workspace 2",
        "go workspace 2",
        "workspace 2",
        "switch to workspace 2",
        "switch workspace 2"
      ],
      "route": "computer_control",
      "function": "close_pig_io_overlay",
      "args": {},
      "tts": false
    },
    {
      "name": "open_pig_hud",
      "description": "Open/show the pig-hud observability sidecar.",
      "match": [
        "open hud",
        "show hud",
        "open pig hud",
        "show pig hud"
      ],
      "route": "computer_control",
      "function": "open_pig_hud",
      "args": {},
      "tts": false
    },
    {
      "name": "close_pig_hud",
      "description": "Close/hide the pig-hud observability sidecar.",
      "match": [
        "close hud",
        "hide hud",
        "close pig hud",
        "hide pig hud"
      ],
      "route": "computer_control",
      "function": "close_pig_hud",
      "args": {},
      "tts": false
    },
    {
      "name": "research_tell_me",
      "description": "Route to Pig/main LLM for web/research answer, then speak the result with TTS.",
      "prefix": "search for ",
      "contains": "tell me about",
      "route": "main_llm_research",
      "function": "ask_pig",
      "tts": true
    }
  ],
  "fallback": {
    "route": "main_llm",
    "function": "ask_pig",
    "tts": true,
    "description": "If it is not one of the directly routed commands (including Firefox/browser/YouTube search requests), send it to the main LLM/Pig."
  }
}
